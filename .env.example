# ── Seguridad ─────────────────────────────────────────────────────────────────
# Generá una clave con: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambiar-en-produccion

DEBUG=False
ALLOWED_HOSTS=spwap.supregsolutions.com
CSRF_TRUSTED_ORIGINS=https://spwap.supregsolutions.com

# ── Base de datos ─────────────────────────────────────────────────────────────
POSTGRES_DB=waply
POSTGRES_USER=waply
POSTGRES_PASSWORD=waply123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Evolution API ─────────────────────────────────────────────────────────────
# URL interna Docker (no usar el puerto del host aquí)
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=tu-api-key
EVOLUTION_INSTANCE_NAME=waply

# ── Webhook ───────────────────────────────────────────────────────────────────
# Token que Evolution API envía en el header "apikey" al hacer POST al webhook
WHATSAPP_WEBHOOK_TOKEN=token-secreto

# ── URL pública ───────────────────────────────────────────────────────────────
PUBLIC_URL=https://spwap.supregsolutions.com

# ── n8n (opcional) ────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_LIBERAR_ASESOR_URL=
CRM_API_KEY=
